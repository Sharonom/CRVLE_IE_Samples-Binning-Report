<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Samples Bucketing</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous" />
    <style>
        :root {
            --intel-blue:  #0068B5;
            --intel-dark:  #00438A;
            --intel-light: #E8F3FC;
        }
        body { background-color: #f0f5fb; }
        /* Navbar */
        .navbar-brand { font-weight: 700; letter-spacing: .5px; font-size: 1.15rem; }
        /* Hero header */
        .app-hero {
            background: linear-gradient(135deg, var(--intel-dark) 0%, var(--intel-blue) 100%);
            color: #fff;
            padding: 2.5rem 1rem 2rem;
            text-align: center;
            margin-bottom: 2rem;
        }
        .app-hero h1 { font-size: 2rem; font-weight: 800; letter-spacing: .5px; margin-bottom: .5rem; }
        .app-hero p  { font-size: 1rem; opacity: .88; max-width: 600px; margin: 0 auto; }
        /* Input card */
        .input-card {
            border: 2px solid var(--intel-blue);
            border-radius: .75rem;
            box-shadow: 0 4px 18px rgba(0,104,181,.15);
        }
        .input-card .card-header {
            background: var(--intel-blue);
            color: #fff;
            font-weight: 600;
            font-size: .95rem;
            border-radius: calc(.75rem - 2px) calc(.75rem - 2px) 0 0;
        }
        .vpo-textarea {
            border: 2px solid #90c4e8;
            border-radius: .5rem;
            transition: border-color .2s, box-shadow .2s;
            background: var(--intel-light);
            font-size: .92rem;
        }
        .vpo-textarea:focus {
            border-color: var(--intel-blue);
            box-shadow: 0 0 0 .25rem rgba(0,104,181,.18);
            background: #fff;
        }
        .vpo-textarea.is-invalid { border-color: #dc3545; }
        /* Buttons */
        .btn-intel {
            background: var(--intel-blue);
            border-color: var(--intel-dark);
            color: #fff;
            font-weight: 600;
        }
        .btn-intel:hover  { background: var(--intel-dark); border-color: var(--intel-dark); color: #fff; }
        .btn-intel:active { transform: scale(.97); }
        /* Results table */
        .results-table thead th { white-space: nowrap; background: var(--intel-dark); color: #fff; }
        .results-table tfoot td  { background: #d0e8f8; font-weight: 700; color: var(--intel-dark); white-space: nowrap; }
        /* Badge tweaks */
        .badge-intel { background-color: var(--intel-blue) !important; }
    </style>
</head>
<body>
    <nav class="navbar navbar-dark shadow-sm" style="background: var(--intel-dark);">
        <div class="container d-flex align-items-center justify-content-between">
            <a class="navbar-brand" href="/">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="me-2 mb-1" viewBox="0 0 16 16">
                    <path d="M0 1.5A1.5 1.5 0 0 1 1.5 0h13A1.5 1.5 0 0 1 16 1.5v13a1.5 1.5 0 0 1-1.5 1.5h-13A1.5 1.5 0 0 1 0 14.5zm1.5-.5a.5.5 0 0 0-.5.5v13a.5.5 0 0 0 .5.5h13a.5.5 0 0 0 .5-.5v-13a.5.5 0 0 0-.5-.5z"/>
                    <path d="M2 3h2v2H2zm0 3h2v2H2zm0 3h2v2H2zm3-6h2v2H5zm0 3h2v2H5zm0 3h2v2H5zm3-6h4v2H8zm0 3h4v2H8zm0 3h4v2H8z"/>
                </svg>
                Samples Bucketing
            </a>
            <div class="d-flex gap-1">
                <a href="/" class="btn btn-sm btn-outline-light px-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" class="me-1" viewBox="0 0 16 16">
                        <path d="M0 1.5A1.5 1.5 0 0 1 1.5 0h13A1.5 1.5 0 0 1 16 1.5v13a1.5 1.5 0 0 1-1.5 1.5h-13A1.5 1.5 0 0 1 0 14.5zm1.5-.5a.5.5 0 0 0-.5.5v13a.5.5 0 0 0 .5.5h13a.5.5 0 0 0 .5-.5v-13a.5.5 0 0 0-.5-.5z"/>
                        <path d="M2 3h2v2H2zm0 3h2v2H2zm0 3h2v2H2zm3-6h2v2H5zm0 3h2v2H5zm0 3h2v2H5zm3-6h4v2H8zm0 3h4v2H8zm0 3h4v2H8z"/>
                    </svg>
                    Bin Split
                </a>
                <a href="/VpoList" class="btn btn-sm btn-outline-light px-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" class="me-1" viewBox="0 0 16 16">
                        <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398l3.85 3.85a1 1 0 0 0 1.415-1.415zm-5.242 1.15a5.5 5.5 0 1 1 0-11 5.5 5.5 0 0 1 0 11"/>
                    </svg>
                    Browse VPOs
                </a>
            </div>
        </div>
    </nav>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmB3jl4dO7L0PFyQOqzgNfFx2Vf"
            crossorigin="anonymous"></script>
    <main>
        @RenderBody()
    </main>
    <footer class="mt-5 py-3 border-top text-center text-muted small">
        Samples Bucketing &mdash; Intel Internal Tool
    </footer>
</body>
</html>
